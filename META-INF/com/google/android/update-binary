#!/sbin/sh
# IVANNA-OMEGA-SUPREME — Magisk Module Installer (raíz del repo)
#
# HISTORIAL:
#   Este script ANTES era un instalador legacy de "IVANNA-FUSION-DSP"
#   con:
#     - library name    = "ivanna_fusion"
#     - .so             = libivanna_fusion.so   (nunca compilada por el CMake actual)
#     - UUID            = 7b3be4ec-c23c-4e6e-8c6d-49e5f4d54ea3
#
#   El motor real de este proyecto es OMEGA y vive en magisk_module/:
#     - library name    = "omega_effect"
#     - .so             = libomega_effect.so    (SÍ compilada, ver CMakeLists.txt)
#     - UUID            = 8d7d5e0a-a6eb-4fde-a0ff-cb1b2dd7275e
#
#   Si alguien empaquetaba el ZIP desde la RAÍZ del repo, terminaba con
#   un módulo Frankenstein: este installer pedía libivanna_fusion.so,
#   nunca la encontraba y abortaba — o peor, si lograba pasar la
#   verificación, patcheaba audio_effects.xml con nombres/UUID que no
#   coincidían con nada compilado -> audioserver crasheaba en boot.
#
# REGLA DE ORO — no borramos, mejoramos:
#   Este archivo NO se elimina (rompería scripts externos de release que
#   asumen su existencia en META-INF/). Se REESCRIBE como un stub honesto
#   que redirige al instalador canónico (magisk_module/customize.sh) y
#   verifica que se está usando el ZIP correcto.
#
# Compatible con: Magisk v24+, KernelSU, APatch.

TMPDIR="$3"
ZIPFILE="$3"
[ -z "$ZIPFILE" ] && ZIPFILE="$1"

ui_print() { echo "$1"; }

ui_print " "
ui_print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
ui_print "  IVANNA-OMEGA-SUPREME — root installer stub"
ui_print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
ui_print " "
ui_print "! Este ZIP se empaquetó desde la raíz del repositorio."
ui_print "! El instalador REAL de Magisk vive en:"
ui_print "!    magisk_module/customize.sh"
ui_print " "
ui_print "! El artefacto correcto para flashear es:"
ui_print "!    ivanna-omega-magisk.zip"
ui_print "! producido por el workflow build.yml (job build-magisk)."
ui_print " "
ui_print "! Consíguelo desde:"
ui_print "!    - GitHub Actions -> artifact 'ivanna-omega-magisk', o"
ui_print "!    - la Release publicada (tag vX.Y)"
ui_print " "
ui_print "! ABORTANDO instalación para no dejar el teléfono con un módulo"
ui_print "! inconsistente (libomega_effect.so faltante, UUID desalineados,"
ui_print "! audio_effects.xml patcheado con nombres que no existen)."
ui_print " "

# abort proviene del entorno Magisk (util_functions.sh)
if command -v abort >/dev/null 2>&1; then
  abort "! Usa ivanna-omega-magisk.zip, no este ZIP de la raíz del repo."
else
  # Fallback si se ejecuta fuera del recovery
  exit 1
fi

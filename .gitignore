
# Android / Gradle
.gradle/
**/.cxx/
**/build/
app/build/

# IDE
.idea/
*.iml

# Local machine config
local.properties
*.keystore
*.jks
keystore.properties

# Secretos — nunca deben versionarse
*.pem
*.key
.env
secrets/
google-services.json

# Logs / cache
*.log

# Build artifacts — deben ir a GitHub Releases, no al árbol fuente
*.apk
*.aab
app/src/main/cpp/tests/build/
app/src/main/cpp/tests/build-asan/
app/src/main/cpp/tests/build-tsan/

# ── Release artifacts que NO deben versionarse ────────────────────────────────
# El repo tenía IVANNA-OMEGA-SUPREME-main (11).zip, -auditado.zip, -v1.6.zip
# viviendo en la raíz (~1.2MB combinados). Se distribuyen por Releases +
# artifacts del workflow build.yml — no por el tree.
*.zip
ivanna-omega-magisk.zip
libomega_effect_arm64.so

# Patches sueltos (git format-patch / diffs manuales) no deben commitearse
# a main. Aplícalos, elimínalos, y deja el commit como registro histórico
# — el .patch en el árbol es ruido y confunde a los reviewers.
*.patch
*.rej
*.orig

# CMake / native build detritus
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Native test binaries
app/src/main/cpp/tests/build*/

# Coverage
**/reports/
*.lcov

# Daemon binary (compiled by CI, not source)
ivanna_daemon
ivanna_daemon.stripped

# Shared library copies from CI validation
libomega_effect_arm64.so
libc++_shared.so


**/*.o
**/*.obj
**/*.so.dbg
**/CMakeCache.txt
**/CMakeFiles/
**/cmake_install.cmake
**/Makefile
app/src/main/cpp/tests/build/
app/src/main/cpp/tests/build-asan/
app/src/main/cpp/tests/build-tsan/
app/src/main/cpp/tests/build-*/

# IDEs
.idea/
*.iml
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Local machine config (NUNCA commitear)
local.properties
*.keystore
*.jks
*.p12
keystore.properties
signing.properties

# Secretos / credenciales (defensa en profundidad)
*.pem
*.key
.env
.env.*
!.env.example
secrets/
**/google-services.json

# Logs / cache
*.log
*.tmp
/tmp/

